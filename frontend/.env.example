# URL de la API (Vite la inyecta en build y en dev vía import.meta.env.VITE_API_URL)
# Si no está definida, el frontend usa por defecto: http://localhost:8000

# ========== DESARROLLO LOCAL ==========
# Copiá este archivo a .env o .env.local y usá la URL local del backend:
#   VITE_API_URL=http://localhost:8000
# Así probás todo en tu máquina (backend + frontend) sin subir a Render.

# ========== PRODUCCIÓN ==========
# En Netlify/Vercel/Render (donde hostees el frontend), configurá en el dashboard
# la variable de entorno:
#   VITE_API_URL=https://loqueellasquierencta.onrender.com
# El build usará esa URL; no hace falta tocarla en el código.

# Ejemplo para desarrollo local (descomentá y usá en .env o .env.local):
# VITE_API_URL=http://localhost:8000

# Ejemplo para producción (solo como referencia; en producción se configura en el hosting):
# VITE_API_URL=https://loqueellasquierencta.onrender.com
